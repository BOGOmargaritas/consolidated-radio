---
import { getCollection } from "astro:content";
import RadioPage from "../../components/radio-page.astro";

export function getStaticPaths() {
  return [
    { params: { number: decodeURI("%5Bnumber%5D") } }, // decodes to "[page]"
  ];
}

const { number } = Astro.params;

const episode = (await getCollection("episodes")).find(
  (episode) => episode.data.number === parseInt(number),
);

if (!episode) {
  return Astro.redirect("/");
}
---

<RadioPage {...episode.data} />
