<html>
  <head> </head>

  <body
    ><canvas id="visualizer"></canvas>
    <audio controls src="/music.mp3"></audio>
  </body>
</html>

<style>
  body {
    overflow: hidden; /* Hides both horizontal and vertical scrollbars and stops scrolling */
    height: 100%; /* Ensures the body takes up the full initial height of the viewport */
    margin: 0; /* Removes default browser margins */
    padding: 0; /* Removes default padding */
  }

  canvas {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: #000; /* black background */
  }
</style>

<script client:load>
  const canvas = document.getElementById("visualizer");
  const ctx = canvas.getContext("2d");

  let w, h, cx, cy;
  function resize() {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
    cx = w / 2;
    cy = h / 2;
  }
  resize();
  window.addEventListener("resize", resize);

  // AUDIO SETUP
  const audio = document.querySelector("audio");
  const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  const source = audioCtx.createMediaElementSource(audio);
  const analyser = audioCtx.createAnalyser();
  source.connect(analyser);
  analyser.connect(audioCtx.destination);

  analyser.fftSize = 512;
  const freqData = new Uint8Array(analyser.frequencyBinCount);

  // RINGS
  const ringCount = 6;
  const rings = Array.from({ length: ringCount }, (_, i) => ({
    radius: (i + 1) * 40,
    speed: 0.2 + i * 0.05,
    rotation: Math.random() * Math.PI * 2,
  }));

  // DRAW
  function draw() {
    requestAnimationFrame(draw);

    analyser.getByteFrequencyData(freqData);
    const bass =
      freqData.slice(0, freqData.length / 4).reduce((a, b) => a + b) /
      (freqData.length / 4) /
      255;
    const treble =
      freqData.slice(freqData.length / 4).reduce((a, b) => a + b) /
      ((freqData.length * 3) / 4) /
      255;

    // fade previous frame slightly for trailing effect
    ctx.fillStyle = "rgba(0,0,0,0.15)";
    ctx.fillRect(0, 0, w, h);

    // DRAW RINGS
    rings.forEach((r, i) => {
      r.rotation += 0.002 + treble * 0.01; // rotate faster on treble
      const currentRadius = r.radius + bass * 100; // expand on bass

      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(r.rotation);

      ctx.beginPath();
      for (let a = 0; a < Math.PI * 2; a += 0.05) {
        let x = Math.cos(a) * currentRadius;
        let y = Math.sin(a) * currentRadius;
        if (a === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.closePath();
      ctx.strokeStyle = "rgba(255,255,255,0.5)";
      ctx.lineWidth = 1.5 + bass * 2;
      ctx.stroke();
      ctx.restore();
    });

    // RADIO SIGNAL LINES
    const lineCount = 20;
    for (let i = 0; i < lineCount; i++) {
      let angle = Math.random() * Math.PI * 2 + treble * 0.5;
      let length = 50 + bass * 200;
      let x1 = cx + Math.cos(angle) * 10;
      let y1 = cy + Math.sin(angle) * 10;
      let x2 = cx + Math.cos(angle) * length;
      let y2 = cy + Math.sin(angle) * length;
      ctx.strokeStyle = "rgba(255,255,255," + (0.1 + Math.random() * 0.2) + ")";
      ctx.lineWidth = 0.5;
      ctx.beginPath();
      ctx.moveTo(x1, y1);
      ctx.lineTo(x2, y2);
      ctx.stroke();
    }

    // SUBTLE NOISE / GLITCH
    if (Math.random() < 0.05) {
      let y = Math.random() * h;
      let slice = ctx.getImageData(0, y, w, 2);
      ctx.putImageData(slice, (Math.random() - 0.5) * 10, y);
    }
  }

  audio.addEventListener("play", () => {
    audioCtx.resume();
  });
  draw();
</script>
