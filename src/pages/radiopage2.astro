<html>
  <head> </head>

  <body
    ><canvas id="visualizer"></canvas>
    <audio controls src="/music.mp3"></audio>
  </body>
</html>

<style>
  body {
    overflow: hidden; /* Hides both horizontal and vertical scrollbars and stops scrolling */
    height: 100%; /* Ensures the body takes up the full initial height of the viewport */
    margin: 0; /* Removes default browser margins */
    padding: 0; /* Removes default padding */
  }

  canvas {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: #000; /* black background */
  }
</style>

<script client:load>
  const canvas = document.getElementById("visualizer");
  const ctx = canvas.getContext("2d");

  let w, h, cx, cy;
  function resize() {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
    cx = w / 2;
    cy = h / 2;
  }
  resize();
  window.addEventListener("resize", resize);

  // AUDIO SETUP
  const audio = document.querySelector("audio");
  const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  const source = audioCtx.createMediaElementSource(audio);
  const analyser = audioCtx.createAnalyser();
  source.connect(analyser);
  analyser.connect(audioCtx.destination);

  analyser.fftSize = 512;
  const freqData = new Uint8Array(analyser.frequencyBinCount);

  // RINGS
  const ringCount = 6;
  const rings = Array.from({ length: ringCount }, (_, i) => ({
    radius: (i + 1) * 40,
    speed: 0.002 + i * 0.001, // subtle rotation
    rotation: Math.random() * Math.PI * 2,
  }));

  // DRAW
  function draw() {
    requestAnimationFrame(draw);

    analyser.getByteFrequencyData(freqData);
    const bass =
      freqData.slice(0, freqData.length / 4).reduce((a, b) => a + b) /
      (freqData.length / 4) /
      255;
    const treble =
      freqData.slice(freqData.length / 4).reduce((a, b) => a + b) /
      ((freqData.length * 3) / 4) /
      255;

    // fade previous frame slightly for trailing effect
    ctx.fillStyle = "rgba(0,0,0,0.15)";
    ctx.fillRect(0, 0, w, h);

    // DRAW RINGS ONLY
    rings.forEach((r, i) => {
      r.rotation += r.speed + treble * 0.005; // rotate subtly with treble
      const currentRadius = r.radius + bass * 100; // expand with bass

      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(r.rotation);

      ctx.beginPath();
      for (let a = 0; a < Math.PI * 2; a += 0.02) {
        let x = Math.cos(a) * currentRadius;
        let y = Math.sin(a) * currentRadius;
        if (a === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.closePath();
      ctx.strokeStyle = "rgba(255,255,255,0.6)";
      ctx.lineWidth = 2 + bass * 2; // subtle thickness change with bass
      ctx.stroke();
      ctx.restore();
    });
  }

  audio.addEventListener("play", () => {
    audioCtx.resume();
  });
  draw();
</script>
