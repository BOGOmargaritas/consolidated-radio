<html>
  <head> </head>

  <body
    ><canvas id="visualizer"></canvas>
    <audio controls src="/music.mp3"></audio>
  </body>
</html>

<style>
  body {
    overflow: hidden; /* Hides both horizontal and vertical scrollbars and stops scrolling */
    height: 100%; /* Ensures the body takes up the full initial height of the viewport */
    margin: 0; /* Removes default browser margins */
    padding: 0; /* Removes default padding */
  }

  canvas {
    position: fixed;
    inset: 0;
    z-index: -1;
  }
</style>

<script client:load>
  const canvas = document.getElementById("visualizer");
  const ctx = canvas.getContext("2d");

  let w, h, cx, cy;
  function resize() {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
    cx = w / 2;
    cy = h / 2;
  }
  resize();
  window.addEventListener("resize", resize);

  // 🎨 KRZ-ish palette
  const colors = ["#594097", "#734BA1", "#C2B0C9", "#F4EFD2", "#55576C"];

  // AUDIO
  const audio = document.querySelector("audio");
  const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  const source = audioCtx.createMediaElementSource(audio);
  const analyser = audioCtx.createAnalyser();

  source.connect(analyser);
  analyser.connect(audioCtx.destination);

  analyser.fftSize = 512;
  const data = new Uint8Array(analyser.frequencyBinCount);

  function draw(time) {
    requestAnimationFrame(draw);

    analyser.getByteFrequencyData(data);

    ctx.clearRect(0, 0, w, h);

    // 🌌 background
    ctx.fillStyle = "#0a0a12";
    ctx.fillRect(0, 0, w, h);

    // 🗺️ TOPOGRAPHIC FLOW LINES
    const lines = 25;

    for (let l = 0; l < lines; l++) {
      ctx.beginPath();

      for (let x = 0; x < w; x += 8) {
        let noise =
          Math.sin(x * 0.01 + time * 0.0005 + l) + Math.cos(x * 0.005 + l * 2);

        let y = (h / lines) * l + noise * 20;

        if (x === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }

      ctx.strokeStyle = colors[l % colors.length] + "33"; // faint
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // 🔊 CIRCULAR WAVEFORM
    const radius = Math.min(w, h) * 0.2;

    ctx.beginPath();

    for (let i = 0; i < data.length; i++) {
      let angle = (i / data.length) * Math.PI * 2;

      let amp = data[i] / 255;
      let r = radius + amp * 80;

      let x = cx + Math.cos(angle) * r;
      let y = cy + Math.sin(angle) * r;

      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    }

    ctx.closePath();

    // glow
    ctx.shadowBlur = 20;
    ctx.shadowColor = "#C2B0C9";

    ctx.strokeStyle = "#F4EFD2";
    ctx.lineWidth = 2;
    ctx.stroke();

    ctx.shadowBlur = 0;

    // 📡 SIGNAL INTERFERENCE (subtle glitch lines)
    if (Math.random() < 0.08) {
      let y = Math.random() * h;

      ctx.fillStyle = "rgba(255,255,255,0.05)";
      ctx.fillRect(0, y, w, 2);

      // horizontal jitter slice
      let sliceHeight = 10 + Math.random() * 20;
      let offset = (Math.random() - 0.5) * 20;

      let img = ctx.getImageData(0, y, w, sliceHeight);
      ctx.putImageData(img, offset, y);
    }

    // subtle vignette
    let grad = ctx.createRadialGradient(cx, cy, radius, cx, cy, w);
    grad.addColorStop(0, "rgba(0,0,0,0)");
    grad.addColorStop(1, "rgba(0,0,0,0.5)");

    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, w, h);
  }

  draw(0);

  // autoplay fix
  audio.addEventListener("play", () => {
    audioCtx.resume();
  });
</script>
