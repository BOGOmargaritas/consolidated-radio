<html>
  <head>
    <meta name="theme-color" content="#000000" />
    <link
      rel="icon"
      type="image/png"
      href="/favicon/favicon-96x96.png"
      sizes="96x96"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicon/apple-touch-icon.png"
    />
    <link rel="manifest" href="/favicon/site.webmanifest" />
  </head>

  <body
    ><canvas id="visualizer"></canvas>
    <audio controls src="/music.mp3"></audio>
    <div class="logo">
      <img src="/badgeicon-cream.png" />
    </div>
  </body>
</html>

<style>
  body {
    overflow: hidden; /* Hides both horizontal and vertical scrollbars and stops scrolling */
    height: 100%; /* Ensures the body takes up the full initial height of the viewport */
    margin: 0; /* Removes default browser margins */
    padding: 0; /* Removes default padding */
  }

  .logo {
  }

  .logo img {
    position: absolute;
    top: 13%; /* Moves the top edge to the vertical center */
    transform: translateY(-50%); /* Pulls the image up by half its own height */
    /* To also center horizontally, add: */
    left: 50%;
    transform: translate(-50%, -50%);
    height: 20%;
  }

  audio {
    position: absolute;
    bottom: 5%; /* Moves the top edge to the vertical center */
    transform: translateY(-50%); /* Pulls the image up by half its own height */
    /* To also center horizontally, add: */
    left: 50%;
    transform: translate(-50%, -50%);
    height: 20%;
  }

  canvas {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: #000; /* black background */
  }

  /* --- Media query for screens narrower than 600px (mobile) --- */
  @media screen and (max-width: 1300px) {
    audio {
      bottom: 1%;
    }
  }
</style>

<script client:load>
  const canvas = document.getElementById("visualizer");
  const ctx = canvas.getContext("2d");

  let w, h, cx, cy;
  function resize() {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
    cx = w / 2;
    cy = h / 2;
  }
  resize();
  window.addEventListener("resize", resize);

  // AUDIO SETUP
  const audio = document.querySelector("audio");
  const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  const source = audioCtx.createMediaElementSource(audio);
  const analyser = audioCtx.createAnalyser();
  source.connect(analyser);
  analyser.connect(audioCtx.destination);

  analyser.fftSize = 512;
  const freqData = new Uint8Array(analyser.frequencyBinCount);

  // PERLIN NOISE
  let perm = new Uint8Array(512);
  for (let i = 0; i < 256; i++) perm[i] = i;
  perm.sort(() => Math.random() - 0.5);
  for (let i = 0; i < 256; i++) perm[i + 256] = perm[i];

  function fade(t) {
    return t * t * t * (t * (t * 6 - 15) + 10);
  }
  function lerp(a, b, t) {
    return a + (b - a) * t;
  }
  function grad(hash, x, y) {
    const h = hash & 3;
    return h === 0 ? x : h === 1 ? -x : h === 2 ? y : -y;
  }
  function noise(x, y) {
    let X = Math.floor(x) & 255,
      Y = Math.floor(y) & 255;
    x -= Math.floor(x);
    y -= Math.floor(y);
    let u = fade(x),
      v = fade(y);
    let a = perm[X] + Y,
      b = perm[X + 1] + Y;
    return lerp(
      lerp(grad(perm[a], x, y), grad(perm[b], x - 1, y), u),
      lerp(grad(perm[a + 1], x, y - 1), grad(perm[b + 1], x - 1, y - 1), u),
      v,
    );
  }

  // RINGS
  const ringCount = 6;
  const rings = Array.from({ length: ringCount }, (_, i) => ({
    radius: (i + 1) * 40,
    speed: 0.002 + i * 0.001,
    rotation: Math.random() * Math.PI * 2,
    noiseOffset: Math.random() * 1000,
    trebleFactor: 1 - i * 0.1, // inner rings more sensitive
  }));

  // EASE VARIABLES
  let playing = false;
  let ease = 0;
  const easeSpeed = 0.02;

  // TIME VARIABLE FOR FLOWING WIGGLE
  let time = 0;

  // AUDIO PLAY/PAUSE
  audio.addEventListener("play", () => {
    audioCtx.resume();
    playing = true;
  });
  audio.addEventListener("pause", () => {
    playing = false;
  });
  audio.addEventListener("ended", () => {
    playing = false;
  });

  // DRAW FUNCTION
  function draw() {
    requestAnimationFrame(draw);

    analyser.getByteFrequencyData(freqData);

    const bass =
      freqData.slice(0, freqData.length / 4).reduce((a, b) => a + b) /
      (freqData.length / 4) /
      255;
    const treble =
      freqData.slice(freqData.length / 4).reduce((a, b) => a + b) /
      ((freqData.length * 3) / 4) /
      255;

    // SMOOTH EASE-IN/OUT
    ease = lerp(ease, playing ? 1 : 0, easeSpeed);

    // fade background slightly for trails
    ctx.fillStyle = "rgba(0,0,0,0.15)";
    ctx.fillRect(0, 0, w, h);

    // increment time for flowing wiggle
    if (playing) time += 0.01;

    // DRAW RINGS
    rings.forEach((r, i) => {
      r.rotation += (r.speed + treble * 0.005) * ease;
      const currentRadius = r.radius + bass * 100 * ease;

      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(r.rotation);

      ctx.beginPath();
      const points = 200;
      for (let p = 0; p <= points; p++) {
        let angle = (p / points) * Math.PI * 2;

        // Flowing wiggle using time + ring-specific treble scaling
        const wiggle =
          noise(
            Math.cos(angle) * 5 + r.noiseOffset + time,
            Math.sin(angle) * 5 + r.noiseOffset + time,
          ) *
          15 *
          ease *
          (1 + treble * 0.5 * r.trebleFactor);

        let x = Math.cos(angle) * (currentRadius + wiggle);
        let y = Math.sin(angle) * (currentRadius + wiggle);

        if (p === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.closePath();

      // Slightly stronger glow
      ctx.shadowBlur = 8;
      ctx.shadowColor = "#ffecdc";
      ctx.strokeStyle = "#ffecdc";
      ctx.lineWidth = 3 + bass * 1 * ease; // thicker lines
      ctx.stroke();
      ctx.shadowBlur = 0;

      ctx.restore();
    });
  }

  draw();
</script>
