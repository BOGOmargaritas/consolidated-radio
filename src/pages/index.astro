---
import DefaultLayout from "../layouts/default.astro";
import RadioPlayer from "../components/radio-player.astro";
import { getCollection } from "astro:content";

const recentEpisode = (await getCollection("episodes"))
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .at(0);
---

<DefaultLayout>
  <canvas id="visualizer"></canvas>
  <div class="logo">
    <img id="logoImg" src="/badge-cream-1.png" />
  </div>
  <nav class="site-nav">
    <a href="/archive/">ARCHIVE</a>
  </nav>
  <div class="ffs">
    <a href="https://fruitfly.supply"><img src="/ffs.png" /></a>
  </div>
  <div class="page-flow">
    {
      recentEpisode && (
        <RadioPlayer
          title={recentEpisode.data.title}
          description={recentEpisode.data.description}
          audioSrc={recentEpisode.data.audioSrc}
          tracks={recentEpisode.data.tracks}
        />
      )
    }
  </div>
</DefaultLayout>

<style>
  :global(body) {
    overflow-x: hidden;
    overflow-y: auto;
  }

  /* z-index layers: 0 = canvas, 1 = player flow, 2 = logo/nav/ffs */

  canvas {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: #000;
  }

  .page-flow {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    min-height: 100dvh;
    box-sizing: border-box;
    pointer-events: none;
  }

  /* LOGO */

  .logo img {
    position: fixed;
    top: 13vh;
    left: 50%;
    transform: translate(-50%, -50%);
    height: 20vh;
    z-index: 2;

    user-select: none;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;

    -webkit-user-drag: none;
    user-drag: none;
  }

  /* NAV */

  nav {
    position: fixed;
    left: 50%;
    top: 24.5vh;
    transform: translate(-50%, -50%);
    z-index: 2;
    font-size: 10px;
    font-family: "OPTIImprovNewWideNine";
    letter-spacing: 2px;
  }

  nav a {
    text-decoration: none;
    color: #ffecdc;
    transition: opacity 0.25s ease-in-out;
  }

  nav a:hover {
    opacity: 75%;
  }

  .ffs img {
    position: fixed;
    right: 3vw;
    bottom: 3vh;
    width: 125px;
    z-index: 2;

    user-select: none;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;

    -webkit-user-drag: none;
    user-drag: none;
    transition: opacity 0.25s ease-in-out;
  }

  .ffs img:hover {
    opacity: 80%;
  }
</style>

<script>
  // ── LOGO ANIMATION ─────────────────────────

  const logoImg = document.getElementById("logoImg");

  const logos = [
    "/badge-cream-1.png",
    "/badge-cream-2.png",
    "/badge-cream-3.png",
  ];

  let logoIndex = 0;
  let logoInterval = null;

  function startLogoAnimation() {
    if (logoInterval) return;

    logoInterval = setInterval(() => {
      logoIndex = (logoIndex + 1) % logos.length;
      logoImg.src = logos[logoIndex];
    }, 1000);
  }

  function stopLogoAnimation() {
    clearInterval(logoInterval);
    logoInterval = null;
    logoIndex = 0;
    logoImg.src = logos[0];
  }

  // ── CANVAS SETUP ───────────────────────────

  const canvas = document.getElementById("visualizer");
  const ctx = canvas.getContext("2d");
  const audio = document.querySelector("audio");

  /** Matches ~800px player artboard; shrinks ring layout on narrow viewports. */
  const VIZ_REF_PX = 800;

  let w, h, cx, cy;
  /** Scale for ring geometry (1 at large viewports, smaller on narrow screens). */
  let vizScale = 1;

  function resize() {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
    cx = w / 2;
    cy = h / 2;
    vizScale = Math.min(1, Math.min(w, h) / VIZ_REF_PX);
  }

  resize();
  window.addEventListener("resize", resize);

  // ── AUDIO CONTEXT ──────────────────────────

  let audioCtx = null;
  let source = null;
  let analyser = null;
  let freqData = null;

  function setupAudioContext() {
    if (audioCtx) return;

    audioCtx = new (window.AudioContext || window.webkitAudioContext)();

    source = audioCtx.createMediaElementSource(audio);
    analyser = audioCtx.createAnalyser();

    analyser.fftSize = 512;

    freqData = new Uint8Array(analyser.frequencyBinCount);

    source.connect(analyser);
    analyser.connect(audioCtx.destination);

    audioCtx.resume();
  }

  // ── MEDIA SESSION ──────────────────────────

  if ("mediaSession" in navigator) {
    navigator.mediaSession.metadata = new MediaMetadata({
      title: "Consolidated Radio",
      artist: "Live Stream",
      album: "",
      artwork: [
        {
          src: "https://consolidated.radio/badgeicon-cream.png",
          sizes: "512x512",
          type: "image/png",
        },
      ],
    });

    navigator.mediaSession.setActionHandler("play", () => audio.play());
    navigator.mediaSession.setActionHandler("pause", () => audio.pause());

    navigator.mediaSession.setActionHandler("stop", () => {
      audio.pause();
      audio.currentTime = 0;
    });
  }

  // ── VISIBILITY ─────────────────────────────

  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState === "hidden") {
      playing = false;
    } else {
      if (!audio.paused) playing = true;
    }
  });

  // ── PLAY STATE ─────────────────────────────

  let playing = false;

  audio.addEventListener("play", () => {
    setupAudioContext();
    playing = true;
    startLogoAnimation();
  });

  audio.addEventListener("pause", () => {
    playing = false;
    stopLogoAnimation();
  });

  audio.addEventListener("ended", () => {
    playing = false;
    stopLogoAnimation();
  });

  // Resume on touch

  document.addEventListener("touchstart", () => {
    if (audioCtx && audioCtx.state === "suspended") audioCtx.resume();
  });

  // ── PERLIN NOISE ───────────────────────────

  let perm = new Uint8Array(512);

  for (let i = 0; i < 256; i++) perm[i] = i;

  perm.sort(() => Math.random() - 0.5);

  for (let i = 0; i < 256; i++) perm[i + 256] = perm[i];

  function fade(t) {
    return t * t * t * (t * (t * 6 - 15) + 10);
  }

  function lerp(a, b, t) {
    return a + (b - a) * t;
  }

  function grad(hash, x, y) {
    const h = hash & 3;
    return h === 0 ? x : h === 1 ? -x : h === 2 ? y : -y;
  }

  function noise(x, y) {
    let X = Math.floor(x) & 255;
    let Y = Math.floor(y) & 255;

    x -= Math.floor(x);
    y -= Math.floor(y);

    let u = fade(x);
    let v = fade(y);

    let a = perm[X] + Y;
    let b = perm[X + 1] + Y;

    return lerp(
      lerp(grad(perm[a], x, y), grad(perm[b], x - 1, y), u),
      lerp(grad(perm[a + 1], x, y - 1), grad(perm[b + 1], x - 1, y - 1), u),
      v,
    );
  }

  // ── RINGS ──────────────────────────────────

  const rings = Array.from({ length: 6 }, (_, i) => ({
    radius: (i + 1) * 40,
    speed: 0.002 + i * 0.001,
    rotation: Math.random() * Math.PI * 2,
    noiseOffset: Math.random() * 1000,
    trebleFactor: 1 - i * 0.1,
  }));

  let ease = 0;
  const easeSpeed = 0.02;
  let time = 0;

  // ── DRAW LOOP ──────────────────────────────

  function draw() {
    requestAnimationFrame(draw);

    const bass =
      analyser && freqData
        ? (analyser.getByteFrequencyData(freqData),
          freqData.slice(0, freqData.length / 4).reduce((a, b) => a + b) /
            (freqData.length / 4) /
            255)
        : 0;

    const treble =
      analyser && freqData
        ? freqData.slice(freqData.length / 4).reduce((a, b) => a + b) /
          ((freqData.length * 3) / 4) /
          255
        : 0;

    ease = lerp(ease, playing ? 1 : 0, easeSpeed);

    ctx.fillStyle = "rgba(0,0,0,0.15)";
    ctx.fillRect(0, 0, w, h);

    if (playing) time += 0.01;

    const s = vizScale;

    rings.forEach((r) => {
      r.rotation += (r.speed + treble * 0.005) * ease;
      const currentRadius = r.radius * s + bass * 100 * s * ease;

      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(r.rotation);
      ctx.beginPath();

      const points = 200;

      for (let p = 0; p <= points; p++) {
        const angle = (p / points) * Math.PI * 2;

        const wiggle =
          noise(
            Math.cos(angle) * 5 + r.noiseOffset + time,
            Math.sin(angle) * 5 + r.noiseOffset + time,
          ) *
          15 *
          s *
          ease *
          (1 + treble * 0.5 * r.trebleFactor);

        const x = Math.cos(angle) * (currentRadius + wiggle);
        const y = Math.sin(angle) * (currentRadius + wiggle);

        p === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }

      ctx.closePath();

      ctx.shadowBlur = 8 * s;
      ctx.shadowColor = "#ffecdc";
      ctx.strokeStyle = "#ffecdc";
      ctx.lineWidth = (3 + bass * 1 * ease) * s;
      ctx.stroke();

      ctx.shadowBlur = 0;

      ctx.restore();
    });
  }

  draw();
</script>
