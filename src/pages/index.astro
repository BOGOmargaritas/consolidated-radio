---
import RadioPage from "../components/radio-page.astro";
import { getCollection } from "astro:content";

const recentEpisode = (await getCollection("episodes"))
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .at(0);
---

<RadioPage {...recentEpisode?.data} />
