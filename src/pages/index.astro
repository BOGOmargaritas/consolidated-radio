<html>
  <head>
    <meta name="theme-color" content="#000000" />
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" />
  </head>

  <body>
    <canvas id="visualizer"></canvas>

    <!-- ✅ IMPORTANT: give it an ID -->
    <audio id="audio" controls playsinline></audio>

    <div class="logo">
      <img src="/badgeicon-cream.png" />
    </div>
  </body>
</html>

<style>
  body {
    margin: 0;
    overflow: hidden;
    background: black;
  }

  canvas {
    position: fixed;
    inset: 0;
    z-index: -1;
  }

  .logo img {
    position: absolute;
    top: 13%;
    left: 50%;
    transform: translate(-50%, -50%);
    height: 20%;
  }

  audio {
    position: absolute;
    bottom: 5%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
</style>

<script>
  const audio = document.getElementById("audio");

  // ✅ PLAYLIST (add more files here)
  const tracks = [
    "/music.mp3",
    // "/music2.mp3",
    // "/music3.mp3"
  ];

  let current = 0;

  // preload next track
  const nextAudio = new Audio();
  nextAudio.preload = "auto";

  function loadTrack(index) {
    audio.src = tracks[index];
    nextAudio.src = tracks[(index + 1) % tracks.length];
  }

  loadTrack(current);

  // 🔥 FAKE STREAM (never let it end)
  audio.addEventListener("timeupdate", () => {
    if (!audio.duration) return;

    const timeLeft = audio.duration - audio.currentTime;

    if (timeLeft < 0.4) {
      current = (current + 1) % tracks.length;

      audio.src = tracks[current];
      audio.currentTime = 0;
      audio.play().catch(() => {});

      nextAudio.src = tracks[(current + 1) % tracks.length];
    }
  });

  // -----------------------------
  // 🎧 VISUALIZER (SAFE VERSION)
  // -----------------------------

  const canvas = document.getElementById("visualizer");
  const ctx = canvas.getContext("2d");

  let w, h, cx, cy;
  function resize() {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
    cx = w / 2;
    cy = h / 2;
  }
  resize();
  window.addEventListener("resize", resize);

  let audioCtx = null;
  let analyser = null;
  let freqData = null;
  let playing = false;

  audio.addEventListener("play", () => {
    if (!audioCtx) {
      audioCtx = new (window.AudioContext || window.webkitAudioContext)();

      const source = audioCtx.createMediaElementSource(audio);
      analyser = audioCtx.createAnalyser();
      analyser.fftSize = 512;

      source.connect(analyser);
      // ❌ DO NOT connect to destination

      freqData = new Uint8Array(analyser.frequencyBinCount);
    }

    audioCtx.resume();
    playing = true;
  });

  audio.addEventListener("pause", () => (playing = false));

  function draw() {
    requestAnimationFrame(draw);

    ctx.fillStyle = "rgba(0,0,0,0.15)";
    ctx.fillRect(0, 0, w, h);

    if (!analyser) return;

    analyser.getByteFrequencyData(freqData);

    const avg = freqData.reduce((a, b) => a + b, 0) / freqData.length / 255;

    ctx.beginPath();
    ctx.arc(cx, cy, 100 + avg * 200, 0, Math.PI * 2);
    ctx.strokeStyle = "#ffecdc";
    ctx.lineWidth = 3;
    ctx.stroke();
  }

  draw();

  // -----------------------------
  // 📱 LOCK SCREEN METADATA
  // -----------------------------
  if ("mediaSession" in navigator) {
    navigator.mediaSession.metadata = new MediaMetadata({
      title: "Consolidated Radio",
      artist: "Live Stream",
    });
  }
</script>
