---
import DefaultLayout from "../layouts/default.astro";
import RadioPlayer from "../components/radio-player.astro";
import { getCollection } from "astro:content";

const episodes = (await getCollection("episodes")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const first = episodes[0];
const firstDate = first
  ? new Date(first.data.date)
      .toLocaleDateString("en-US", {
        month: "2-digit",
        day: "2-digit",
        year: "numeric",
      })
      .replace(/\//g, ".")
  : "";
---

<DefaultLayout title="Archive — Consolidated Radio" hideVisualizer>
  <div class="archive-flow">
    <div class="archive-content">
      <div class="ep-list" id="epList">
        {
          episodes.map((ep, i) => {
            const dateStr = new Date(ep.data.date)
              .toLocaleDateString("en-US", {
                month: "2-digit",
                day: "2-digit",
                year: "numeric",
              })
              .replace(/\//g, ".");
            return (
              <>
                {i === 0 && <div class="latest-label">LATEST EPISODE</div>}
                <div
                  class={`ep-card-wrapper${i === 0 ? " active" : ""}`}
                  data-title={ep.data.title}
                  data-date={dateStr}
                  data-desc={ep.data.description}
                  data-tracks={JSON.stringify(ep.data.tracks)}
                >
                  <RadioPlayer
                    title={ep.data.title}
                    image={ep.data.image}
                    description={ep.data.description}
                    audioSrc={ep.data.audioSrc}
                    tracks={ep.data.tracks}
                    hideInfoPanel
                  />
                </div>
              </>
            );
          })
        }
      </div>

      <div class="ep-detail" id="epDetail">
        <div class="detail-header" id="detailTitle">
          {first ? first.data.title : "SELECT AN EPISODE"}
        </div>

        <div
          class="detail-desc-box"
          id="detailDesc"
          style={first ? "" : "display:none"}
        >
          <div class="detail-desc-label">DESCRIPTION:</div>
          <div class="detail-description" id="descText">
            {first ? first.data.description : ""}
          </div>
          <div class="detail-date" id="descDate">{firstDate}</div>
        </div>

        <div
          class="detail-track-box"
          id="detailTrack"
          style={first ? "" : "display:none"}
        >
          <div class="detail-tracklist-label">TRACKLIST:</div>
          <div class="detail-tracklist" id="tracklistEl">
            {
              first &&
                first.data.tracks.map(
                  (t: { artist: string; title: string }) => (
                    <div class="track-row">
                      <div class="dot" />
                      <div class="track-name">
                        {t.artist} - {t.title}
                      </div>
                    </div>
                  ),
                )
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</DefaultLayout>

<style>
  .archive-flow {
    position: relative;
    z-index: 1;
    min-height: 100dvh;
    padding-top: 30vh;
    box-sizing: border-box;
  }

  .archive-content {
    display: grid;
    grid-template-columns: 480px 1fr;
    gap: 28px;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px 60px;
    align-items: start;
  }

  /* ── LEFT: EPISODE LIST ────────────────────── */

  .ep-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-height: 72vh;
    overflow-y: auto;
    scrollbar-width: thin;
    padding-right: 8px;
  }
  .ep-list::-webkit-scrollbar {
    width: 4px;
  }
  .ep-list::-webkit-scrollbar-thumb {
    background: #c23b22;
    border-radius: 2px;
  }
  .ep-list::-webkit-scrollbar-track {
    background: transparent;
  }

  .latest-label {
    font-family: "OPTIImprovNewWideNine", sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    color: #ffecdc;
    text-align: center;
    padding-bottom: 2px;
  }

  /* ── CARD WRAPPER ──────────────────────────── */

  .ep-card-wrapper {
    cursor: pointer;
    border-radius: 20px;
    transition:
      transform 0.12s,
      box-shadow 0.2s;
  }
  .ep-card-wrapper.active {
    border-radius: 20px;
  }

  .ep-card-wrapper :global(.radio-player-root) {
    width: 100%;
    padding-bottom: 0;
    margin: 0;
  }

  /* ── RIGHT: DETAIL PANEL ───────────────────── */

  .ep-detail {
    display: flex;
    flex-direction: column;
    gap: 18px;
    position: sticky;
    top: 30vh;
    padding-top: 22px;
  }

  .detail-header {
    font-family: "OPTIImprovNewWideNine", sans-serif;
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    line-height: 1.05;
    letter-spacing: 0.04em;
    color: #ffecdc;
    border-bottom: 4px solid #ffecdc;
    padding-bottom: 12px;
  }

  /* ── DESCRIPTION BOX ───────────────────────── */

  .detail-desc-box {
    background: #ffecdc;
    border: 2px solid #ffecdc;
    border-radius: 18px;
    font-family: "OPTIImprovNewWideNine", sans-serif;
    overflow: hidden;
  }

  .detail-desc-label {
    padding: 4px 13px 6px;
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    color: #000;
  }

  .detail-description {
    font-size: 0.65rem;
    line-height: 1.7;
    color: #ffecdc;
    text-align: justify;
    background: #000;
    padding: 10px 16px;
  }

  .detail-date {
    font-size: 0.8rem;
    letter-spacing: 0.03em;
    color: #000;
    font-weight: 900;
    background: #ffecdc;
    padding: 2px 13px;
  }

  /* ── TRACKLIST BOX ─────────────────────────── */

  .detail-track-box {
    background: #ffecdc;
    border: 2px solid #ffecdc;
    border-radius: 18px;
    overflow: hidden;
    font-family: "OPTIImprovNewWideNine", sans-serif;
  }

  .detail-tracklist-label {
    padding: 4px 13px 6px;
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    color: #000;
  }

  .detail-tracklist {
    display: flex;
    flex-direction: column;
  }

  .detail-tracklist :global(.track-row) {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: #000;
    border-bottom: 1.5px solid #ffecdc;
  }

  .detail-tracklist :global(.track-row:last-child) {
    border-bottom: none;
  }

  .detail-tracklist :global(.dot) {
    width: 6px;
    height: 6px;
    background: #ffecdc;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .detail-tracklist :global(.track-name) {
    font-family: "OPTIImprovNewWideNine", sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.07em;
    color: #ffecdc;
    font-weight: 900;
  }

  /* ── RESPONSIVE ────────────────────────────── */

  @media (max-width: 900px) {
    .archive-flow {
      padding-top: 28vh;
    }

    .archive-content {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 0 14px 40px;
    }

    .ep-list {
      padding-right: 0;
      max-height: 50vh;
    }

    .ep-detail {
      position: static;
      border-top: 2px solid rgba(255, 236, 220, 0.15);
      padding-top: 20px;
    }
  }
</style>

<script>
  const wrappers =
    document.querySelectorAll<HTMLDivElement>(".ep-card-wrapper");

  function selectEpisode(wrapper: HTMLDivElement) {
    wrappers.forEach((w) => w.classList.remove("active"));
    wrapper.classList.add("active");

    const title = wrapper.dataset.title!;
    const desc = wrapper.dataset.desc!;
    const date = wrapper.dataset.date!;
    const tracks: { artist: string; title: string }[] = JSON.parse(
      wrapper.dataset.tracks!,
    );

    document.getElementById("detailTitle")!.textContent = title;
    document.getElementById("descText")!.textContent = desc;
    document.getElementById("descDate")!.textContent = date;
    document.getElementById("detailDesc")!.style.display = "";
    document.getElementById("detailTrack")!.style.display = "";

    const tl = document.getElementById("tracklistEl")!;
    tl.innerHTML = tracks
      .map(
        (t) =>
          `<div class="track-row"><div class="dot"></div><div class="track-name">${t.artist} - ${t.title}</div></div>`,
      )
      .join("");
  }

  wrappers.forEach((wrapper) => {
    wrapper.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (target.closest(".scrubber-track") || target.closest(".vol-track"))
        return;
      selectEpisode(wrapper);
    });
  });

  if (wrappers.length > 0 && !wrappers[0].classList.contains("active")) {
    selectEpisode(wrappers[0]);
  }
</script>
