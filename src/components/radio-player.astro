---
interface Props {
  title: string;
  description: string;
  audioSrc: string;
  tracks: {
    artist: string;
    title: string;
  }[];
  /** When set, fixes `--player-scale` (disables responsive clamp). */
  scale?: number;
  /** When set, overrides default control sizing multiplier. */
  controlScale?: number;
}

const { title, description, audioSrc, tracks, scale, controlScale } = Astro.props;

const playerStyle = [
  scale != null && `--player-scale: ${scale}`,
  controlScale != null && `--control-scale: ${controlScale}`,
]
  .filter(Boolean)
  .join("; ");
---

<div class="radio-player-root">
  <div class="player-wrapper" style={playerStyle || undefined}>
    <div class="player-grid">
      <div class="art-col"></div>

      <div class="right-col">
      <div class="header">
        <div class="ep-title">{title}</div>
      </div>

      <div class="player">
        <div class="player-controls">
          <div class="transport">
            <button class="play-btn" id="playBtn">
              <svg id="playIcon" viewBox="20 8 42 65">
                <path d="M 22 20 Q 22 16 25.4 18.1 L 56.6 37.9 Q 60 40 56.6 42.1 L 25.4 61.9 Q 22 64 22 60 Z" fill="#e8d5b7"></path>
              </svg>
            </button>

            <div class="scrubber-col">
              <div class="scrubber-track" id="scrubber">
                <div class="scrubber-fill" id="sFill"></div>
                <div class="scrubber-thumb" id="sThumb"></div>
              </div>
              <div class="time-row">
                <span id="tCur">00.00</span>
                <span id="tEnd">00.00</span>
              </div>
            </div>
          </div>

          <div class="bottom-row">
            <button class="info-btn" id="infoBtn">
              <svg xmlns="http://www.w3.org/2000/svg" class="info-btn-svg" viewBox="0 0 2000 2000">
                <path
                  fill="#e8d5b7"
                  d="M1511.78,544.32v1086.67c0,159.11-77.1,230.81-108.18,260.64-295.63,283.73-770.54-70.42-580.71-435.77,94.78-182.43,294.4-235.83,483.56-174.74V210.78c0-113.44,3.52-157.96,27.44-178.43,21.46-18.37,50.91-26.05,78.66-26.89,41.45-1.26,82.26,10.23,121.82,21.26,97.09,27.06,197.79,57.62,278.02,121.1,1.94,1.53,3.86,3.08,5.77,4.65,56.83,46.74,99.92,107.86,127.59,175.86,28.47,69.98,41.02,145.68,43.07,220.95,1.11,40.73-.28,82.03-5.33,122.49-4.27,38.9-23.1,60.76-64.09,51.64l-407.59-179.08Z"
                ></path>
                <path fill="#e8d5b7" d="M94.11,341.38l867.93-1.85c114.08,0,112.08,204.3-.34,204.3H93.01c-115.64,0-103.64-202.45,1.1-202.45Z"></path>
                <path fill="#e8d5b7" d="M94.11,1072.18l608.87-1.85c114.08,0,112.08,204.3-.34,204.3H93.01c-115.64,0-103.64-202.45,1.1-202.45Z"></path>
                <path fill="#e8d5b7" d="M94.11,703.71l867.93-1.85c114.08,0,112.08,204.3-.34,204.3H93.01c-115.64,0-103.64-202.45,1.1-202.45Z"></path>
              </svg>
              INFO
            </button>

            <div class="vol-row">
              <svg class="vol-icon" viewBox="0 0 24 24" aria-hidden="true">
                <polygon points="2,9 7,9 13,4 13,20 7,15 2,15" fill="#e8d5b7"></polygon>
                <path d="M16 9c1.5 1.5 1.5 4.5 0 6" stroke="#e8d5b7" stroke-width="2" stroke-linecap="round" fill="none"></path>
                <path d="M19 7c3 3 3 7 0 10" stroke="#e8d5b7" stroke-width="2" stroke-linecap="round" fill="none"></path>
              </svg>

              <div class="vol-track" id="volTrack">
                <div class="vol-fill" id="vFill"></div>
                <div class="vol-thumb" id="vThumb"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="info-panel" id="infoPanel">
    <div class="description">
      {description}
    </div>

    <div class="tracklist-section">
      <div class="tracklist-label">TRACKLIST:</div>
      <div class="tracklist">
        {
          tracks.map(({ artist, title }) => (
            <div class="track-row">
              <div class="dot" />
              <div class="track-name">
                {artist} - {title}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
  </div>
</div>

<audio id="audio" src={audioSrc} playsinline webkit-playsinline></audio>

<style>
  @font-face {
    font-family: "OPTIImprovNewWideNine";
    src: url("/fonts/OPTIImprovNewWideNine.otf") format("opentype");
    font-weight: normal;
    font-style: normal;
  }

  /* Full ~800px design at scale 1; shrinks when the root is narrower than 800px. */
  .radio-player-root {
    container-type: inline-size;
    width: 100%;
    max-width: 800px;
    margin-inline: auto;
  }

  .player-wrapper {
    --control-scale: 1.45;
    --player-scale: clamp(0.3, calc(100dvw / 800px), 1);
    box-sizing: border-box;
    width: 100%;
    max-width: calc(800px * var(--player-scale));
    border: calc(3px * var(--player-scale)) solid #e8d5b7;
    overflow: hidden;
    font-family: "OPTIImprovNewWideNine", sans-serif;
    background: #e8d5b7;
    border-radius: calc(30px * var(--player-scale));
  }

  @supports (width: 1cqi) {
    .player-wrapper {
      --player-scale: clamp(0.3, calc(100cqi / 800px), 1);
    }
  }

  .player-grid {
    display: grid;
    grid-template-columns: calc(160px * var(--player-scale)) 1fr;
    margin: calc(5px * var(--player-scale));
    gap: calc(5px * var(--player-scale));
  }

  .art-col {
    background: #c23b22;
    border-radius: calc(23px * var(--player-scale)) 0 0 calc(23px * var(--player-scale));
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .art-col img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .right-col {
    display: flex;
    flex-direction: column;
    background: #e8d5b7;
  }

  .header {
    padding: calc(4px * var(--player-scale)) calc(6px * var(--player-scale)) calc(10px * var(--player-scale))
      calc(16px * var(--player-scale));
    display: flex;
    align-items: center;
  }

  .ep-title {
    font-size: calc(1.45rem * var(--player-scale));
    font-weight: 900;
    letter-spacing: 0.04em;
    color: #1c1c1c;
    line-height: 1;
  }

  .player {
    --ctrl: calc(var(--player-scale) * var(--control-scale));
    padding: calc(5px * var(--player-scale)) calc(10px * var(--player-scale)) calc(5px * var(--player-scale))
      calc(18px * var(--player-scale));
    background: #1c1c1c;
    border-radius: 0 0 calc(23px * var(--player-scale)) 0;
    display: flex;
    flex-direction: column;
    flex: 1;
    justify-content: center;
    min-height: 0;
  }

  .player-controls {
    display: flex;
    flex-direction: column;
    gap: calc(4px * var(--ctrl));
    width: 100%;
  }

  #playIcon {
    display: block;
    width: calc(52px * var(--ctrl));
    height: calc(80px * var(--ctrl));
  }

  .info-btn-svg {
    display: block;
    width: calc(21px * var(--ctrl));
    height: calc(21px * var(--ctrl));
    flex-shrink: 0;
  }

  .transport {
    display: flex;
    align-items: center;
    gap: calc(10px * var(--ctrl));
  }

  .play-btn {
    background: none;
    border: none;
    cursor: pointer;
    width: calc(60px * var(--ctrl));
    height: calc(80px * var(--ctrl));
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-shrink: 0;
    padding: 0;
  }

  .scrubber-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: calc(4px * var(--ctrl));
    padding-top: calc(15px * var(--ctrl));
    padding-right: calc(7px * var(--ctrl));
  }

  .scrubber-track {
    height: calc(5px * var(--ctrl));
    background: #e8d5b7;
    border-radius: 100px;
    position: relative;
    cursor: pointer;
  }

  .scrubber-fill {
    height: 100%;
    background: #e8d5b7;
    border-radius: 100px;
    width: 0%;
    opacity: 1;
  }

  .scrubber-thumb {
    width: calc(14px * var(--ctrl));
    height: calc(14px * var(--ctrl));
    background: #e8d5b7;
    border-radius: 50%;
    position: absolute;
    top: 50%;
    left: 0%;
    transform: translate(-50%, -50%);
    opacity: 1;
  }

  .time-row {
    display: flex;
    justify-content: space-between;
    font-size: calc(0.55rem * var(--ctrl));
    font-weight: 700;
    color: #e8d5b7;
    letter-spacing: 0.04em;
  }

  .bottom-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-left: calc(2px * var(--ctrl));
  }

  .info-btn {
    background: none;
    border: none;
    color: #e8d5b7;
    font-size: calc(0.8rem * var(--ctrl));
    font-weight: 900;
    letter-spacing: 0.12em;
    cursor: pointer;
    font-family: "OPTIImprovNewWideNine", sans-serif;
    display: flex;
    align-items: center;
    gap: calc(6px * var(--ctrl));
    padding: 0;
  }

  .vol-row {
    display: flex;
    align-items: center;
    gap: calc(8px * var(--ctrl));
    margin-right: calc(10px * var(--ctrl));
  }

  .vol-icon {
    display: block;
    flex-shrink: 0;
    width: calc(28px * var(--ctrl));
    height: calc(28px * var(--ctrl));
  }

  .vol-track {
    width: calc(80px * var(--ctrl));
    height: calc(5px * var(--ctrl));
    background: #e8d5b7;
    border-radius: 100px;
    position: relative;
    cursor: pointer;
  }

  .vol-fill {
    height: 100%;
    background: #e8d5b7;
    border-radius: 100px;
    width: 80%;
    opacity: 1;
  }

  .vol-thumb {
    width: calc(14px * var(--ctrl));
    height: calc(14px * var(--ctrl));
    background: #e8d5b7;
    border-radius: 50%;
    position: absolute;
    top: 50%;
    left: 80%;
    transform: translate(-50%, -50%);
    opacity: 1;
  }

  .info-panel {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition:
      max-height 0.35s ease,
      opacity 0.25s ease;
  }

  .description {
    padding: calc(6px * var(--player-scale)) calc(14px * var(--player-scale)) calc(12px * var(--player-scale));
    font-size: calc(0.85rem * var(--player-scale));
    font-weight: 700;
    line-height: 1.3;
    color: #1c1c1c;
    letter-spacing: 0.01em;
    border-bottom: calc(5.5px * var(--player-scale)) solid #1c1c1c;
    text-align: justify;
  }

  .tracklist-section {
    background: #e8d5b7;
  }

  .tracklist-label {
    padding: calc(5px * var(--player-scale)) calc(13px * var(--player-scale)) calc(6px * var(--player-scale));
    font-size: calc(1.15rem * var(--player-scale));
    font-weight: 900;
    letter-spacing: 0.1em;
    color: #1c1c1c;
  }

  .track-row {
    display: flex;
    align-items: center;
    gap: calc(12px * var(--player-scale));
    padding: calc(6px * var(--player-scale)) calc(16px * var(--player-scale));
    background: #1c1c1c;
    border-bottom: calc(2px * var(--player-scale)) solid #e8d5b7;
  }

  .track-row:last-child {
    border-bottom: none;
  }

  .dot {
    width: calc(8px * var(--player-scale));
    height: calc(8px * var(--player-scale));
    background: #e8d5b7;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .track-name {
    color: #e8d5b7;
    font-size: calc(1.05rem * var(--player-scale));
    font-weight: 900;
    letter-spacing: 0.07em;
  }
</style>

<script>
  /* TIME FORMAT */

  function formatTime(s: number) {
    if (isNaN(s) || s < 0) return "00.00";
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    const sec = Math.floor(s % 60);
    if (h > 0) {
      return `${String(h).padStart(2, "0")}.${String(m).padStart(2, "0")}.${String(sec).padStart(2, "0")}`;
    }
    return `${String(m).padStart(2, "0")}.${String(sec).padStart(2, "0")}`;
  }

  /* INFO TOGGLE */

  const infoBtn = document.getElementById("infoBtn")!;
  const infoPanel = document.getElementById("infoPanel") as HTMLElement;
  let infoOpen = false;

  infoBtn.addEventListener("click", () => {
    infoOpen = !infoOpen;
    if (infoOpen) {
      infoPanel.style.maxHeight = infoPanel.scrollHeight + "px";
      infoPanel.style.opacity = "1";
    } else {
      infoPanel.style.maxHeight = "0";
      infoPanel.style.opacity = "0";
    }
  });

  /* AUDIO */

  const audio = document.getElementById("audio") as HTMLAudioElement;
  audio.volume = 0.8;

  const tCur = document.getElementById("tCur")!;
  const tEnd = document.getElementById("tEnd")!;

  audio.ondurationchange = () => {
    tEnd.textContent = formatTime(audio.duration);
  };

  /* PLAY */

  const playBtn = document.getElementById("playBtn")!;
  const playIcon = document.getElementById("playIcon")!;

  const PLAY = `<path d="M 22 20 Q 22 16 25.4 18.1 L 56.6 37.9 Q 60 40 56.6 42.1 L 25.4 61.9 Q 22 64 22 60 Z" fill="#e8d5b7"/>`;
  const PAUSE = `
    <rect x="22" y="18" width="12" height="44" rx="4" fill="#e8d5b7"/>
    <rect x="44" y="18" width="12" height="44" rx="4" fill="#e8d5b7"/>
  `;

  playBtn.onclick = () => {
    if (audio.paused) {
      audio.play();
      playIcon.innerHTML = PAUSE;
    } else {
      audio.pause();
      playIcon.innerHTML = PLAY;
    }
  };

  /* PROGRESS DRAG */

  const scrub = document.getElementById("scrubber")!;
  const fill = document.getElementById("sFill")!;
  const thumb = document.getElementById("sThumb")!;

  let dragging = false;

  function updateScrub(x: number) {
    const rect = scrub.getBoundingClientRect();
    let pct = (x - rect.left) / rect.width;
    pct = Math.max(0, Math.min(1, pct));
    audio.currentTime = pct * audio.duration;
    fill.style.width = thumb.style.left = pct * 100 + "%";
  }

  scrub.addEventListener("mousedown", (e) => {
    dragging = true;
    updateScrub(e.clientX);
  });

  window.addEventListener("mousemove", (e) => {
    if (dragging) updateScrub(e.clientX);
  });

  window.addEventListener("mouseup", () => (dragging = false));

  audio.ontimeupdate = () => {
    if (!audio.duration) return;
    const pct = audio.currentTime / audio.duration;
    if (!dragging) {
      fill.style.width = thumb.style.left = pct * 100 + "%";
    }
    tCur.textContent = formatTime(audio.currentTime);
  };

  /* VOLUME DRAG */

  const vol = document.getElementById("volTrack")!;
  const vFill = document.getElementById("vFill")!;
  const vThumb = document.getElementById("vThumb")!;

  let volDrag = false;

  function updateVol(x: number) {
    const rect = vol.getBoundingClientRect();
    let pct = (x - rect.left) / rect.width;
    pct = Math.max(0, Math.min(1, pct));
    audio.volume = pct;
    vFill.style.width = vThumb.style.left = pct * 100 + "%";
  }

  vol.addEventListener("mousedown", (e) => {
    volDrag = true;
    updateVol(e.clientX);
  });

  window.addEventListener("mousemove", (e) => {
    if (volDrag) updateVol(e.clientX);
  });

  window.addEventListener("mouseup", () => (volDrag = false));
</script>
