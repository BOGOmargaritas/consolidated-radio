</div>

<style>
  @font-face {
    font-family: "OPTIImprovNewWideNine";
    src: url("/fonts/OPTIImprovNewWideNine.otf") format("opentype");
    font-weight: normal;
    font-style: normal;
  }

  .radio-player-root {
    container-type: inline-size;
    flex-shrink: 0;
    width: min(560px, calc(100vw - 24px));
    box-sizing: border-box;
    margin-inline: auto;
    padding-bottom: 30px;
    pointer-events: auto;
  }

  @media (max-height: 1200px) {
    .radio-player-root {
      width: min(430px, calc(100vw - 24px));
      padding-bottom: 20px;
    }
  }

  @media (max-width: 900px) {
    .radio-player-root {
      width: min(400px, calc(100vw - 52px));
      margin-bottom: 10px;
    }
  }

  .player-wrapper {
    --control-scale: 1.45;
    --player-scale: 0.625;
    box-sizing: border-box;
    width: 100%;
    max-width: calc(800px * var(--player-scale));
    border: calc(3px * var(--player-scale)) solid #ffecdc;
    overflow: hidden;
    font-family: "OPTIImprovNewWideNine", sans-serif;
    background: #ffecdc;
    border-radius: calc(30px * var(--player-scale));
  }

  .player-grid {
    display: grid;
    grid-template-columns: calc(160px * var(--player-scale)) 1fr;
    margin: calc(5px * var(--player-scale));
    gap: calc(6px * var(--player-scale));
  }

  .art-col {
    background: #000000;
    border-radius: calc(23px * var(--player-scale)) 0 0
      calc(23px * var(--player-scale));
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .art-col img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .right-col {
    display: flex;
    flex-direction: column;
    background: #ffecdc;
  }

  .header {
    padding: calc(4px * var(--player-scale)) calc(6px * var(--player-scale))
      calc(10px * var(--player-scale)) calc(16px * var(--player-scale));
    display: flex;
    align-items: center;
  }

  .ep-title {
    font-size: calc(1.45rem * var(--player-scale));
    font-weight: 900;
    letter-spacing: 0.04em;
    color: #000000;
    line-height: 1;
  }

  .player {
    --ctrl: calc(var(--player-scale) * var(--control-scale));
    padding: calc(5px * var(--player-scale)) calc(10px * var(--player-scale))
      calc(5px * var(--player-scale)) calc(18px * var(--player-scale));
    background: #000000;
    border-radius: 0 0 calc(23px * var(--player-scale)) 0;
    display: flex;
    flex-direction: column;
    flex: 1;
    justify-content: center;
    min-height: 0;
  }

  .player-controls {
    display: flex;
    flex-direction: column;
    gap: calc(4px * var(--ctrl));
    width: 100%;
  }

  .play-icon {
    display: block;
    width: calc(52px * var(--ctrl));
    height: calc(80px * var(--ctrl));
  }

  .info-btn-svg {
    display: block;
    width: calc(21px * var(--ctrl));
    height: calc(21px * var(--ctrl));
    flex-shrink: 0;
  }

  .transport {
    display: flex;
    align-items: center;
    gap: calc(10px * var(--ctrl));
  }

  .play-btn {
    background: none;
    border: none;
    cursor: pointer;
    width: calc(60px * var(--ctrl));
    height: calc(80px * var(--ctrl));
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-shrink: 0;
    padding: 0;
  }

  .scrubber-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: calc(4px * var(--ctrl));
    padding-top: calc(15px * var(--ctrl));
    padding-right: calc(7px * var(--ctrl));
  }

  .scrubber-track {
    height: calc(5px * var(--ctrl));
    background: #ffecdc;
    border-radius: 100px;
    position: relative;
    cursor: pointer;
  }

  .scrubber-fill {
    height: 100%;
    background: #ffecdc;
    border-radius: 100px;
    width: 0%;
    opacity: 1;
  }

  .scrubber-thumb {
    width: calc(14px * var(--ctrl));
    height: calc(14px * var(--ctrl));
    background: #ffecdc;
    border-radius: 50%;
    position: absolute;
    top: 50%;
    left: 0%;
    transform: translate(-50%, -50%);
    opacity: 1;
  }

  .time-row {
    display: flex;
    justify-content: space-between;
    font-size: calc(0.55rem * var(--ctrl));
    font-weight: 700;
    color: #ffecdc;
    letter-spacing: 0.04em;
  }

  .bottom-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-left: calc(2px * var(--ctrl));
  }

  .info-btn {
    background: none;
    border: none;
    color: #ffecdc;
    font-size: calc(0.8rem * var(--ctrl));
    font-weight: 900;
    letter-spacing: 0.12em;
    cursor: pointer;
    font-family: "OPTIImprovNewWideNine", sans-serif;
    display: flex;
    align-items: center;
    gap: calc(6px * var(--ctrl));
    padding: 0;
  }

  .skip-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .skip-btn-svg {
    display: block;
    width: calc(38px * var(--ctrl));
    height: calc(21px * var(--ctrl));
  }

  .vol-row {
    display: flex;
    align-items: center;
    gap: calc(8px * var(--ctrl));
    margin-right: calc(10px * var(--ctrl));
  }

  .vol-icon {
    display: block;
    flex-shrink: 0;
    width: calc(28px * var(--ctrl));
    height: calc(28px * var(--ctrl));
  }

  .vol-track {
    width: calc(80px * var(--ctrl));
    height: calc(5px * var(--ctrl));
    background: #ffecdc;
    border-radius: 100px;
    position: relative;
    cursor: pointer;
  }

  .vol-fill {
    height: 100%;
    background: #ffecdc;
    border-radius: 100px;
    width: 80%;
    opacity: 1;
  }

  .vol-thumb {
    width: calc(14px * var(--ctrl));
    height: calc(14px * var(--ctrl));
    background: #ffecdc;
    border-radius: 50%;
    position: absolute;
    top: 50%;
    left: 80%;
    transform: translate(-50%, -50%);
    opacity: 1;
  }

  .info-panel {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition:
      max-height 0.35s ease,
      opacity 0.25s ease;
  }

  .description {
    padding: calc(6px * var(--player-scale)) calc(14px * var(--player-scale))
      calc(12px * var(--player-scale));
    font-size: calc(0.85rem * var(--player-scale));
    font-weight: 700;
    line-height: 1.3;
    color: #000000;
    letter-spacing: 0.01em;
    border-bottom: calc(5.5px * var(--player-scale)) solid #000000;
    text-align: justify;
  }

  .tracklist-section {
    background: #ffecdc;
  }

  .tracklist-label {
    padding: calc(5px * var(--player-scale)) calc(13px * var(--player-scale))
      calc(6px * var(--player-scale));
    font-size: calc(1.15rem * var(--player-scale));
    font-weight: 900;
    letter-spacing: 0.1em;
    color: #000000;
  }

  .track-row {
    display: flex;
    align-items: center;
    gap: calc(12px * var(--player-scale));
    padding: calc(6px * var(--player-scale)) calc(16px * var(--player-scale));
    background: #000000;
    border-bottom: calc(2px * var(--player-scale)) solid #ffecdc;
  }

  .track-row:last-child {
    border-bottom: none;
  }

  .dot {
    width: calc(8px * var(--player-scale));
    height: calc(8px * var(--player-scale));
    background: #ffecdc;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .track-name {
    color: #ffecdc;
    font-size: calc(1.05rem * var(--player-scale));
    font-weight: 900;
    letter-spacing: 0.07em;
  }
</style>

<script>
  const PLAY = `<path d="M 22 20 Q 22 16 25.4 18.1 L 56.6 37.9 Q 60 40 56.6 42.1 L 25.4 61.9 Q 22 64 22 60 Z" fill="#ffecdc"/>`;
  const PAUSE = `<rect x="22" y="18" width="12" height="44" rx="4" fill="#ffecdc"/><rect x="44" y="18" width="12" height="44" rx="4" fill="#ffecdc"/>`;

  function formatTime(s: number) {
    if (isNaN(s) || s < 0) return "00.00";
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    const sec = Math.floor(s % 60);
    if (h > 0) {
      return `${String(h).padStart(2, "0")}.${String(m).padStart(2, "0")}.${String(sec).padStart(2, "0")}`;
    }
    return `${String(m).padStart(2, "0")}.${String(sec).padStart(2, "0")}`;
  }

  document
    .querySelectorAll<HTMLElement>(".radio-player-root")
    .forEach((root) => {
      const wrapper = root.querySelector<HTMLElement>(".player-wrapper")!;
      const audio = root.querySelector<HTMLAudioElement>("audio")!;
      const skipTime = 30; // Time in seconds
      audio.crossOrigin = "anonymous";

      /** Attempt to fix lockscreen seek showing wrong number */
      if ("mediaSession" in navigator) {
        navigator.mediaSession.setActionHandler("play", () => {
          audio.play();
        });

        navigator.mediaSession.setActionHandler("pause", () => {
          audio.pause();
        });

        navigator.mediaSession.setActionHandler("seekforward", (details) => {
          audio.currentTime += details.seekOffset || 30;
        });

        navigator.mediaSession.setActionHandler("seekbackward", (details) => {
          audio.currentTime -= details.seekOffset || 10;
        });

        navigator.mediaSession.setActionHandler("seekto", (details) => {
          if (details.seekTime != null) {
            audio.currentTime = details.seekTime;
          }
        });
      }
      /** End attempt*/

      const title =
        root.querySelector(".ep-title")?.textContent?.trim() ??
        "Consolidated Radio";

      const artwork = "https://consolidated.radio/episodeimage.png";

      const playBtn = root.querySelector<HTMLButtonElement>(".play-btn")!;
      const playIcon = root.querySelector<SVGElement>(".play-icon")!;
      const scrub = root.querySelector<HTMLElement>(".scrubber-track")!;
      const fill = root.querySelector<HTMLElement>(".scrubber-fill")!;
      const thumb = root.querySelector<HTMLElement>(".scrubber-thumb")!;
      const tCur = root.querySelector<HTMLElement>(".time-cur")!;
      const tEnd = root.querySelector<HTMLElement>(".time-end")!;
      const vol = root.querySelector<HTMLElement>(".vol-track")!;
      const vFill = root.querySelector<HTMLElement>(".vol-fill")!;
      const vThumb = root.querySelector<HTMLElement>(".vol-thumb")!;
      const skipBackBtn =
        root.querySelector<HTMLButtonElement>(".skip-back-btn")!;
      const skipFwdBtn =
        root.querySelector<HTMLButtonElement>(".skip-fwd-btn")!;
      const infoBtn = root.querySelector<HTMLButtonElement>(".info-btn");
      const infoPanel = root.querySelector<HTMLElement>(".info-panel");

      /* RESPONSIVE SCALE */
      if (!wrapper.hasAttribute("data-fixed-scale")) {
        const updateScale = () => {
          const s = Math.max(0.3, Math.min(root.clientWidth / 800, 1));
          wrapper.style.setProperty("--player-scale", String(s));
        };
        updateScale();
        new ResizeObserver(updateScale).observe(root);
      }

      /* INFO TOGGLE (only when panel exists) */
      let infoOpen = false;
      if (infoBtn && infoPanel) {
        infoBtn.addEventListener("click", () => {
          infoOpen = !infoOpen;
          if (infoOpen) {
            infoPanel.style.maxHeight = infoPanel.scrollHeight + "px";
            infoPanel.style.opacity = "1";
          } else {
            infoPanel.style.maxHeight = "0";
            infoPanel.style.opacity = "0";
          }
        });
      }

      /* AUDIO */
      audio.volume = 0.8;

      audio.addEventListener("loadedmetadata", () => {
        tEnd.textContent = formatTime(audio.duration);
      });

      audio.addEventListener("durationchange", () => {
        tEnd.textContent = formatTime(audio.duration);
      });

      // Metadata may already be loaded before this script ran (fast CDN /
      // cached response), in which case the events above never fire. Read the
      // current state directly to cover that race.
      if (audio.readyState >= 1 /* HAVE_METADATA */ && !isNaN(audio.duration)) {
        tEnd.textContent = formatTime(audio.duration);
      }

      /* Cross-player exclusivity: pause others when this one plays */
      audio.addEventListener("play", () => {
        playIcon.innerHTML = PAUSE;

        if ("mediaSession" in navigator) {
          navigator.mediaSession.metadata = new MediaMetadata({
            title,
            artist: "Consolidated Radio",
            album: "Consolidated Radio",
            artwork: [
              {
                src: artwork,
                sizes: "1200x1200",
                type: "image/png",
              },
            ],
          });

          navigator.mediaSession.setActionHandler("play", () => audio.play());
          navigator.mediaSession.setActionHandler("pause", () => audio.pause());
          navigator.mediaSession.setActionHandler("seekbackward", () =>
            seekBy(-10),
          );
          navigator.mediaSession.setActionHandler("seekforward", () =>
            seekBy(30),
          );
        }

        document
          .querySelectorAll<HTMLAudioElement>(".radio-player-root audio")
          .forEach((other) => {
            if (other !== audio && !other.paused) {
              other.pause();
            }
          });
      });

      audio.addEventListener("pause", () => {
        playIcon.innerHTML = PLAY;
      });

      audio.addEventListener("ended", () => {
        playIcon.innerHTML = PLAY;
        fill.style.width = "0%";
        thumb.style.left = "0%";
        tCur.textContent = "00.00";
      });

      /* PLAY BUTTON */
      playBtn.addEventListener("click", () => {
        if (audio.paused) {
          audio.play();
        } else {
          audio.pause();
        }
      });

      /* SKIP BUTTONS */
      function seekBy(seconds: number) {
        const duration = audio.duration;
        if (!duration) return;
        audio.currentTime = Math.max(
          0,
          Math.min(duration, audio.currentTime + seconds),
        );
      }

      skipBackBtn.addEventListener("click", () => seekBy(-10));
      skipFwdBtn.addEventListener("click", () => seekBy(30));

      /* SCRUBBER DRAG */
      let dragging = false;

      function updateScrub(x: number) {
        const rect = scrub.getBoundingClientRect();
        let pct = (x - rect.left) / rect.width;
        pct = Math.max(0, Math.min(1, pct));
        if (audio.duration) audio.currentTime = pct * audio.duration;
        fill.style.width = pct * 100 + "%";
        thumb.style.left = pct * 100 + "%";
      }

      scrub.addEventListener("mousedown", (e) => {
        dragging = true;
        updateScrub(e.clientX);
      });

      window.addEventListener("mousemove", (e) => {
        if (dragging) updateScrub(e.clientX);
      });

      window.addEventListener("mouseup", () => {
        dragging = false;
      });

      audio.addEventListener("timeupdate", () => {
        if (!audio.duration) return;
        const pct = audio.currentTime / audio.duration;
        if (!dragging) {
          fill.style.width = pct * 100 + "%";
          thumb.style.left = pct * 100 + "%";
        }
        tCur.textContent = formatTime(audio.currentTime);
      });

      /* VOLUME DRAG */
      let volDrag = false;

      function updateVol(x: number) {
        const rect = vol.getBoundingClientRect();
        let pct = (x - rect.left) / rect.width;
        pct = Math.max(0, Math.min(1, pct));
        audio.volume = pct;
        vFill.style.width = pct * 100 + "%";
        vThumb.style.left = pct * 100 + "%";
      }

      vol.addEventListener("mousedown", (e) => {
        volDrag = true;
        updateVol(e.clientX);
      });

      window.addEventListener("mousemove", (e) => {
        if (volDrag) updateVol(e.clientX);
      });

      window.addEventListener("mouseup", () => {
        volDrag = false;
      });
    });
</script>

<script>
  // Runs immediately on the client side once the DOM is ready
  document.addEventListener("DOMContentLoaded", () => {
    const audio = document.querySelector(
      ".radio-player-root audio",
    ) as HTMLAudioElement;
    const skipFwdBtn = document.querySelector(".skip-fwd-btn");
    const skipBackBtn = document.querySelector(".skip-back-btn");

    if (!audio) return;

    const skipTime = 30;

    // Helper function to handle seek logic safely
    function seek(amount: number) {
      if (!audio.duration) return;
      let newTime = audio.currentTime + amount;
      if (newTime < 0) newTime = 0;
      if (newTime > audio.duration) newTime = audio.duration;
      audio.currentTime = newTime;

      // Force iOS to sync the visual scrubber position immediately
      if ("mediaSession" in navigator) {
        navigator.mediaSession.setPositionState({
          duration: audio.duration || 0,
          playbackRate: audio.playbackRate || 1,
          position: audio.currentTime || 0,
        });
      }
    }

    // 1. Hook up iOS System Controls (Lock screen / Control Center)
    if ("mediaSession" in navigator) {
      navigator.mediaSession.setActionHandler("seekbackward", (details) => {
        // iOS sometimes sends a specific offset, fallback to default 30s
        const offset = details.seekOffset || skipTime;
        seek(-offset);
      });

      navigator.mediaSession.setActionHandler("seekforward", (details) => {
        const offset = details.seekOffset || skipTime;
        seek(offset);
      });

      // Keep playback state synced so iOS doesn't lose track of the audio
      audio.addEventListener("play", () => {
        navigator.mediaSession.playbackState = "playing";
      });
      audio.addEventListener("pause", () => {
        navigator.mediaSession.playbackState = "paused";
      });
    }

    // 2. Tie it to your existing layout HTML buttons (Optional but recommended)
    if (skipFwdBtn) {
      skipFwdBtn.addEventListener("click", () => seek(skipTime));
    }
    if (skipBackBtn) {
      skipBackBtn.addEventListener("click", () => seek(-skipTime));
    }
  });
</script>
