---
interface Props {
  title: string;
  description: string;
  audioSrc: string;
  image: string;
  tracks: {
    artist: string;
    title: string;
  }[];
  /** When set, fixes `--player-scale` (disables responsive clamp). */
  scale?: number;
  /** When set, overrides default control sizing multiplier. */
  controlScale?: number;
  /** Hides the built-in info panel (description + tracklist). */
  hideInfoPanel?: boolean;
}

const {
  title,
  description,
  audioSrc,
  image,
  tracks,
  scale,
  controlScale,
  hideInfoPanel = false,
} = Astro.props;

const playerStyle = [
  scale != null && `--player-scale: ${scale}`,
  controlScale != null && `--control-scale: ${controlScale}`,
]
  .filter(Boolean)
  .join("; ");

console.log(image);
---

<div class="radio-player-root">
  <audio
    src={audioSrc}
    crossorigin="anonymous"
    playsinline
    webkit-playsinline
    preload="metadata"></audio>
  <div
    class="player-wrapper"
    style={playerStyle || undefined}
    data-fixed-scale={scale != null ? "" : undefined}
  >
    <div class="player-grid">
      <div class="art-col">
        <img src={image} alt={title} />
      </div>

      <div class="right-col">
        <div class="header">
          <div class="ep-title">{title}</div>
        </div>

        <div class="player">
          <div class="player-controls">
            <div class="transport">
              <button class="play-btn">
                <svg class="play-icon" viewBox="20 8 42 65">
                  <path
                    d="M 22 20 Q 22 16 25.4 18.1 L 56.6 37.9 Q 60 40 56.6 42.1 L 25.4 61.9 Q 22 64 22 60 Z"
                    fill="#ffecdc"></path>
                </svg>
              </button>

              <div class="scrubber-col">
                <div class="scrubber-track">
                  <div class="scrubber-fill"></div>
                  <div class="scrubber-thumb"></div>
                </div>
                <div class="time-row">
                  <span class="time-cur">00.00</span>
                  <span class="time-end">00.00</span>
