---
interface Props {
  title: string;
  description: string;
  audioSrc: string;
  tracks: {
    artist: string;
    title: string;
  }[];
}

const { title, description, audioSrc, tracks } = Astro.props;
---

<div class="player-wrapper">
  <div class="player-grid">
    <div class="art-col"></div>

    <div class="right-col">
      <div class="header">
        <div class="ep-title">{title}</div>
      </div>

      <div class="player">
        <div class="transport">
          <button class="play-btn" id="playBtn">
            <svg id="playIcon" viewBox="0 0 80 80" width="64" height="64">
              <polygon points="22,16 60,40 22,64" fill="#e8d5b7" stroke-linejoin="round" stroke-linecap="round"></polygon>
            </svg>
          </button>

          <div class="scrubber-col">
            <div class="scrubber-track" id="scrubber">
              <div class="scrubber-fill" id="sFill"></div>
              <div class="scrubber-thumb" id="sThumb"></div>
            </div>
            <div class="time-row">
              <span id="tCur">00.00</span>
              <span id="tEnd">00.00</span>
            </div>
          </div>
        </div>

        <div class="bottom-row">
          <button class="info-btn" id="infoBtn">
            <svg width="18" height="15" viewBox="0 0 18 15" fill="none">
              <path d="M1 13V3.5L7 1v10M1 13l6-2.5" stroke="#e8d5b7" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round"></path>
              <path d="M7 1l9-1v10L7 11.5" stroke="#e8d5b7" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round"></path>
              <circle cx="4" cy="13" r="2.2" fill="#e8d5b7"></circle>
              <circle cx="13" cy="10" r="2.2" fill="#e8d5b7"></circle>
            </svg>
            INFO
          </button>

          <div class="vol-row">
            <svg class="vol-icon" width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
              <polygon points="2,9 7,9 13,4 13,20 7,15 2,15" fill="#e8d5b7"></polygon>
              <path d="M16 9c1.5 1.5 1.5 4.5 0 6" stroke="#e8d5b7" stroke-width="2" stroke-linecap="round" fill="none"></path>
              <path d="M19 7c3 3 3 7 0 10" stroke="#e8d5b7" stroke-width="2" stroke-linecap="round" fill="none"></path>
            </svg>

            <div class="vol-track" id="volTrack">
              <div class="vol-fill" id="vFill"></div>
              <div class="vol-thumb" id="vThumb"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="info-panel" id="infoPanel">
    <div class="description">
      {description}
    </div>

    <div class="tracklist-section">
      <div class="tracklist-label">TRACKLIST:</div>
      <div class="tracklist">
        {
          tracks.map(({ artist, title }) => (
            <div class="track-row">
              <div class="dot" />
              <div class="track-name">
                {artist} - {title}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</div>

<audio id="audio"></audio>

<style>
  .player-wrapper {
    width: 640px;
    border: 3px solid #1c1c1c;
    border-radius: 12px;
    overflow: hidden;
    font-family: "Barlow Condensed", sans-serif;
    background: #e8d5b7;
  }

  .player-grid {
    display: grid;
    grid-template-columns: 120px 1fr;
    margin: 5px;
    gap: 5px;
  }

  .art-col {
    background: #c23b22;
    border-radius: 10px 0 0 10px;
  }

  .right-col {
    display: flex;
    flex-direction: column;
    background: #e8d5b7;
  }

  .header {
    padding: 5px 14px 6px;
  }

  .ep-title {
    font-size: 1.45rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    color: #1c1c1c;
  }

  .player {
    padding: 12px 14px;
    background: #1c1c1c;
    border-radius: 0 0 10px 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
    justify-content: center;
  }

  .transport {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .play-btn {
    background: none;
    border: none;
    cursor: pointer;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    padding: 0;
  }

  .scrubber-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 12px;
  }

  .scrubber-track {
    height: 3px;
    background: #e8d5b7;
    border-radius: 100px;
    position: relative;
    cursor: pointer;
    opacity: 0.5;
  }

  .scrubber-fill {
    height: 100%;
    background: #e8d5b7;
    border-radius: 100px;
    width: 0%;
    opacity: 1;
  }

  .scrubber-thumb {
    width: 10px;
    height: 10px;
    background: #e8d5b7;
    border-radius: 50%;
    position: absolute;
    top: 50%;
    left: 0%;
    transform: translate(-50%, -50%);
    opacity: 1;
  }

  .time-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.65rem;
    font-weight: 700;
    color: #e8d5b7;
    letter-spacing: 0.04em;
  }

  .bottom-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .info-btn {
    background: none;
    border: none;
    color: #e8d5b7;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    cursor: pointer;
    font-family: "Barlow Condensed", sans-serif;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0;
  }

  .vol-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-right: 10px;
  }

  .vol-icon {
    display: block;
    flex-shrink: 0;
  }

  .vol-track {
    width: 60px;
    height: 3px;
    background: #e8d5b7;
    border-radius: 100px;
    position: relative;
    cursor: pointer;
    opacity: 0.5;
  }

  .vol-fill {
    height: 100%;
    background: #e8d5b7;
    border-radius: 100px;
    width: 80%;
    opacity: 1;
  }

  .vol-thumb {
    width: 10px;
    height: 10px;
    background: #e8d5b7;
    border-radius: 50%;
    position: absolute;
    top: 50%;
    left: 80%;
    transform: translate(-50%, -50%);
    opacity: 1;
  }

  .info-panel {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition:
      max-height 0.35s ease,
      opacity 0.25s ease;
  }

  .description {
    padding: 12px 14px 14px;
    font-size: 0.85rem;
    font-weight: 700;
    line-height: 1.5;
    color: #1c1c1c;
    letter-spacing: 0.01em;
    border-bottom: 2px solid #1c1c1c;
  }

  .tracklist-section {
    background: #e8d5b7;
  }

  .tracklist-label {
    padding: 12px 20px 10px;
    font-size: 1.15rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    color: #1c1c1c;
  }

  .track-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 16px;
    background: #1c1c1c;
    border-bottom: 2px solid #e8d5b7;
  }

  .track-row:last-child {
    border-bottom: none;
  }

  .dot {
    width: 8px;
    height: 8px;
    background: #e8d5b7;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .track-name {
    color: #e8d5b7;
    font-size: 1.05rem;
    font-weight: 900;
    letter-spacing: 0.07em;
  }
</style>

<script>
  /* TIME FORMAT */

  function formatTime(s: number) {
    if (isNaN(s) || s < 0) return "00.00";
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    const sec = Math.floor(s % 60);
    if (h > 0) {
      return `${String(h).padStart(2, "0")}.${String(m).padStart(2, "0")}.${String(sec).padStart(2, "0")}`;
    }
    return `${String(m).padStart(2, "0")}.${String(sec).padStart(2, "0")}`;
  }

  /* INFO TOGGLE */

  const infoBtn = document.getElementById("infoBtn")!;
  const infoPanel = document.getElementById("infoPanel") as HTMLElement;
  let infoOpen = false;

  infoBtn.addEventListener("click", () => {
    infoOpen = !infoOpen;
    if (infoOpen) {
      infoPanel.style.maxHeight = infoPanel.scrollHeight + "px";
      infoPanel.style.opacity = "1";
    } else {
      infoPanel.style.maxHeight = "0";
      infoPanel.style.opacity = "0";
    }
  });

  /* AUDIO */

  const audio = document.getElementById("audio") as HTMLAudioElement;
  audio.volume = 0.8;

  const tCur = document.getElementById("tCur")!;
  const tEnd = document.getElementById("tEnd")!;

  audio.ondurationchange = () => {
    tEnd.textContent = formatTime(audio.duration);
  };

  /* PLAY */

  const playBtn = document.getElementById("playBtn")!;
  const playIcon = document.getElementById("playIcon")!;

  const PLAY = `<polygon points="22,16 60,40 22,64" fill="#e8d5b7"/>`;
  const PAUSE = `
    <rect x="22" y="18" width="12" height="44" rx="4" fill="#e8d5b7"/>
    <rect x="44" y="18" width="12" height="44" rx="4" fill="#e8d5b7"/>
  `;

  playBtn.onclick = () => {
    if (audio.paused) {
      audio.play();
      playIcon.innerHTML = PAUSE;
    } else {
      audio.pause();
      playIcon.innerHTML = PLAY;
    }
  };

  /* PROGRESS DRAG */

  const scrub = document.getElementById("scrubber")!;
  const fill = document.getElementById("sFill")!;
  const thumb = document.getElementById("sThumb")!;

  let dragging = false;

  function updateScrub(x: number) {
    const rect = scrub.getBoundingClientRect();
    let pct = (x - rect.left) / rect.width;
    pct = Math.max(0, Math.min(1, pct));
    audio.currentTime = pct * audio.duration;
    fill.style.width = thumb.style.left = pct * 100 + "%";
  }

  scrub.addEventListener("mousedown", (e) => {
    dragging = true;
    updateScrub(e.clientX);
  });

  window.addEventListener("mousemove", (e) => {
    if (dragging) updateScrub(e.clientX);
  });

  window.addEventListener("mouseup", () => (dragging = false));

  audio.ontimeupdate = () => {
    if (!audio.duration) return;
    const pct = audio.currentTime / audio.duration;
    if (!dragging) {
      fill.style.width = thumb.style.left = pct * 100 + "%";
    }
    tCur.textContent = formatTime(audio.currentTime);
  };

  /* VOLUME DRAG */

  const vol = document.getElementById("volTrack")!;
  const vFill = document.getElementById("vFill")!;
  const vThumb = document.getElementById("vThumb")!;

  let volDrag = false;

  function updateVol(x: number) {
    const rect = vol.getBoundingClientRect();
    let pct = (x - rect.left) / rect.width;
    pct = Math.max(0, Math.min(1, pct));
    audio.volume = pct;
    vFill.style.width = vThumb.style.left = pct * 100 + "%";
  }

  vol.addEventListener("mousedown", (e) => {
    volDrag = true;
    updateVol(e.clientX);
  });

  window.addEventListener("mousemove", (e) => {
    if (volDrag) updateVol(e.clientX);
  });

  window.addEventListener("mouseup", () => (volDrag = false));
</script>
