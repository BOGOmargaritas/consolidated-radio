      </div>
    </div>

    {
      !hideInfoPanel && (
        <div class="info-panel">
          <div class="description">{description}</div>

          <div class="tracklist-section">
            <div class="tracklist-label">TRACKLIST:</div>
            <div class="tracklist">
              {tracks.map(({ artist, title }) => (
                <div class="track-row">
                  <div class="dot" />
